@using SettlersOfIdlestan.Model.Buildings
@using SettlersOfIdlestan.Model.City
@using SettlersOfIdlestan.Model.IslandMap
@using SettlersOfIdlestan.Controller
@using System.Linq

@if (City is null)
{
    <p class="text-muted">Aucune ville sélectionnée. Cliquez sur une ville dans la carte.</p>
}
else
{
    <p class="mb-1"><strong>Niveau :</strong> <span class="badge bg-primary">@City.LevelName (@City.Level)</span></p>

    <h6 class="mb-1">Bâtiments</h6>

    {
        var built      = City.Buildings ?? new List<Building>();
        var buildables = BuildingController?.GetBuildableBuildings(City.CivilizationIndex, City.Position)
                         ?? new List<Building>();
        var allTypes   = Enum.GetValues(typeof(BuildingType)).Cast<BuildingType>().ToList();

        <ul class="list-group mb-2">
            @foreach (var t in allTypes)
            {
                var builtB = built.FirstOrDefault(b => b.Type == t);
                var proto  = buildables.FirstOrDefault(b => b.Type == t);
                var desc   = builtB?.Description ?? proto?.Description ?? string.Empty;

                var rowClass = builtB != null
                    ? "list-group-item list-group-item-success"
                    : proto  != null
                        ? "list-group-item"
                        : "list-group-item list-group-item-light text-muted";

                <li class="@rowClass" title="@desc">
                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <strong>@t</strong>
                            @if (builtB != null)
                            {
                                <span class="ms-1 badge bg-success">Niv.&nbsp;@builtB.Level&thinsp;/&thinsp;@builtB.MaxLevel</span>
                            }
                        </div>

                        <div>
                            @if (builtB != null && builtB.Level < builtB.MaxLevel)
                            {
                                <button class="btn btn-sm btn-outline-primary"
                                        @onclick="() => DoAction(t)">Améliorer</button>
                            }
                            else if (builtB != null)
                            {
                                <span class="badge bg-secondary">Max</span>
                            }
                            else if (proto != null)
                            {
                                <button class="btn btn-sm btn-primary"
                                        @onclick="() => DoAction(t)">Construire</button>
                            }
                            else
                            {
                                <span class="badge bg-light text-secondary border">—</span>
                            }
                        </div>

                    </div>

                    @* Cost / unavailability hint *@
                    @if (builtB != null && builtB.Level < builtB.MaxLevel)
                    {
                        <div class="mt-1"><small class="fst-italic">@FormatCost(builtB.GetUpgradeCost(builtB.Level + 1))</small></div>
                    }
                    else if (proto != null)
                    {
                        <div class="mt-1"><small class="fst-italic">@FormatCost(proto.GetBuildCost())</small></div>
                    }
                    else if (builtB == null)
                    {
                        <div class="mt-1"><small class="fst-italic text-muted">Non disponible</small></div>
                    }
                </li>
            }
        </ul>
    }

    @if (!string.IsNullOrEmpty(_message))
    {
        <div class="mt-1 @(_isError ? "text-danger" : "text-success") small">@_message</div>
    }
}

@code {
    [Parameter, EditorRequired] public City?               City                { get; set; }
    [Parameter, EditorRequired] public BuildingController? BuildingController  { get; set; }
    [Parameter]                 public EventCallback       OnBuildingChanged   { get; set; }

    private string? _message;
    private bool    _isError;

    private async Task DoAction(BuildingType type)
    {
        if (City == null || BuildingController == null) return;
        var isUpgrade = City.Buildings?.Any(b => b.Type == type) == true;
        try
        {
            BuildingController.BuildBuilding(City.CivilizationIndex, City.Position, type);
            _message = isUpgrade ? "Bâtiment amélioré ✓" : "Bâtiment construit ✓";
            _isError = false;
            await OnBuildingChanged.InvokeAsync();
        }
        catch (Exception ex)
        {
            _message  = ex.Message;
            _isError  = true;
        }
    }

    private static string FormatCost(Dictionary<Resource, int> cost)
    {
        if (cost == null || cost.Count == 0) return "Aucun coût";
        return string.Join(", ", cost.Select(kv => $"{kv.Value} {kv.Key}"));
    }
}
