@page "/"
@layout SettlersOfIdlestanWeb.Layout.GameLayout
@using SkiaSharp
@using SkiaSharp.Views.Blazor
@using SettlersOfIdlestanSkia.Services
@inject IFileSystemService FileSystemService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div style="position: relative; width: 100vw; height: 100vh; overflow: hidden; background: #000; margin: 0; padding: 0;">

    <SKGLView @ref="_canvasView"
              OnPaintSurface="OnPaintSurface"
              style="position: absolute; inset: 0; width: 100%; height: 100%;" />

    @* Transparent overlay captures all pointer/wheel events so OffsetX/Y are always canvas-relative *@
    <div style="position: absolute; inset: 0;"
         @onmousedown="OnMouseDown"
         @onmousemove="OnMouseMove"
         @onmouseup="OnMouseUp"
         @onwheel="OnWheel"
         @oncontextmenu="OnContextMenu"
         @oncontextmenu:preventDefault="true"
         @onmousedown:preventDefault="false" />


</div>

@code {
    private SKGLView? _canvasView;
    private SkiaGameRuntime? _runtime;
    private CancellationTokenSource? _cts;
    private bool _initialized;
    private DotNetObjectReference<Game>? _dotNetRef;
    private int _keyboardHandlerId = -1;
    private float _dpr = 1f;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _initialized)
            return;

        _initialized = true;

        try
        {
            _runtime = new SkiaGameRuntime();
            _runtime.QuitRequested += () => _ = JS.InvokeVoidAsync("window.close");
            await _runtime.InitializeAsync(FileSystemService);
        }
        catch (Exception ex)
        {
            _runtime?.NotifyError(ex);
            await JS.InvokeVoidAsync("gameInterop.logError", ex.ToString());
            return;
        }

        _dpr = (float)await JS.InvokeAsync<double>("gameInterop.getDevicePixelRatio");

        _dotNetRef = DotNetObjectReference.Create(this);
        _keyboardHandlerId = await JS.InvokeAsync<int>("gameInterop.registerKeyboardHandler", _dotNetRef);
        await JS.InvokeVoidAsync("gameInterop.registerVisibilityHandler", _dotNetRef);

        _cts = new CancellationTokenSource();
        _ = RunGameLoop(_cts.Token);
    }

    private async Task RunGameLoop(CancellationToken ct)
    {
        while (!ct.IsCancellationRequested)
        {
            try
            {
                _runtime?.Tick();
                _canvasView?.Invalidate();
                await Task.Delay(16, ct);
            }
            catch (TaskCanceledException)
            {
                break;
            }
            catch (Exception ex)
            {
                _runtime?.NotifyError(ex);
                await JS.InvokeVoidAsync("gameInterop.logError", ex.ToString());
                break;
            }
        }
    }

    private void OnPaintSurface(SKPaintGLSurfaceEventArgs e)
    {
        if (_runtime == null)
            return;

        try
        {
            var canvasSize = new SKSize(e.BackendRenderTarget.Width, e.BackendRenderTarget.Height);
            _runtime.EnsureCanvasInitialized(canvasSize);
            _runtime.Render(e.Surface.Canvas);
        }
        catch (Exception ex)
        {
            _runtime?.NotifyError(ex);
            _ = JS.InvokeVoidAsync("gameInterop.logError", ex.ToString());
        }
    }

    private void OnMouseDown(MouseEventArgs e)
        => _runtime?.HandlePointerPressed((float)e.OffsetX * _dpr, (float)e.OffsetY * _dpr, 0, ToPointerButton(e.Button));

    private void OnMouseMove(MouseEventArgs e)
        => _runtime?.HandlePointerMoved((float)e.OffsetX * _dpr, (float)e.OffsetY * _dpr, 0);

    private void OnMouseUp(MouseEventArgs e)
        => _runtime?.HandlePointerReleased((float)e.OffsetX * _dpr, (float)e.OffsetY * _dpr, 0, ToPointerButton(e.Button));

    private void OnWheel(WheelEventArgs e)
    {
        // DeltaY positive = scroll down = zoom out → negative wheelDelta for HandleZoom
        _runtime?.HandleZoom((float)-e.DeltaY, (float)e.OffsetX * _dpr, (float)e.OffsetY * _dpr);
    }

    private void OnContextMenu(MouseEventArgs e) { }

    [JSInvokable]
    public void OnKeyDown(string key) => _runtime?.HandleKeyPressed(key);

    [JSInvokable]
    public void OnKeyUp(string key) => _runtime?.HandleKeyReleased(key);

    [JSInvokable]
    public void OnPageVisible(double hiddenSeconds) => _runtime?.NotifyPageVisible(hiddenSeconds);

    private static PointerButton ToPointerButton(long button) => button switch
    {
        0 => PointerButton.Left,
        1 => PointerButton.Middle,
        2 => PointerButton.Right,
        _ => PointerButton.Unknown,
    };

    public async ValueTask DisposeAsync()
    {
        if (_cts != null)
        {
            await _cts.CancelAsync();
            _cts.Dispose();
            _cts = null;
        }

        if (_keyboardHandlerId >= 0)
        {
            await JS.InvokeVoidAsync("gameInterop.unregisterKeyboardHandler", _keyboardHandlerId);
            _keyboardHandlerId = -1;
        }

        await JS.InvokeVoidAsync("gameInterop.unregisterVisibilityHandler");

        _dotNetRef?.Dispose();
        _dotNetRef = null;

        _runtime?.Dispose();
        _runtime = null;
    }
}
