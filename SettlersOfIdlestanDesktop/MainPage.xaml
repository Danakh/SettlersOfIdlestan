<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:skia="clr-namespace:SkiaSharp.Views.Maui.Controls;assembly=SkiaSharp.Views.Maui.Controls"
             x:Class="SettlersOfIdlestanDesktop.MainPage"
             Title="Settlers of Idlestan">

    <Grid RowDefinitions="*, Auto"
          ColumnDefinitions="*, 320">

        <!-- Canvas SkiaSharp pour le rendu du jeu -->
        <skia:SKCanvasView x:Name="GameCanvas"
                           Grid.Row="0"
                           Grid.Column="0"
                           PaintSurface="OnCanvasPaintSurface"
                           EnableTouchEvents="True"
                           Touch="OnCanvasTouch"
                           Background="White" />

        <!-- Barre d'état minimale -->
        <StackLayout Grid.Row="1"
                     Grid.Column="0"
                     Orientation="Horizontal"
                     Padding="10"
                     Spacing="10"
                     BackgroundColor="#f0f0f0">
            <Label x:Name="FpsLabel"
                   Text="FPS: 0"
                   FontSize="12"
                   VerticalOptions="Center" />
            <Label x:Name="CameraLabel"
                   Text="Camera: 0,0"
                   FontSize="12"
                   VerticalOptions="Center" />
            <Label x:Name="StateLabel"
                   Text="Chargement..."
                   FontSize="12"
                   VerticalOptions="Center"
                   HorizontalOptions="FillAndExpand" />
        </StackLayout>

        <!-- Panneau fixe de sélection -->
        <ScrollView Grid.Row="0"
                    Grid.Column="1"
                    Grid.RowSpan="2"
                    BackgroundColor="#202020">
            <VerticalStackLayout Padding="14"
                                 Spacing="10">
                <Label Text="Selection"
                       FontSize="18"
                       FontAttributes="Bold"
                       TextColor="White" />

                <Label Text="Type de ville"
                       FontSize="12"
                       TextColor="#BFBFBF" />
                <Label x:Name="SelectedCityTypeLabel"
                       Text="Aucune"
                       FontSize="14"
                       TextColor="White" />

                <BoxView HeightRequest="1"
                         BackgroundColor="#404040" />

                <Label Text="Batiments"
                       FontSize="12"
                       TextColor="#BFBFBF" />
                <VerticalStackLayout x:Name="SelectedCityBuildingsList"
                                     Spacing="6" />
            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>
